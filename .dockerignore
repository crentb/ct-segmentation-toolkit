# Keep the build context (and image) small + reproducible.
# (Comments must be on their own lines; .dockerignore has no inline comments.)
.git
.github
# ~2 MB of architecture PDFs/PNGs; not needed at runtime
docs/
# pipeline outputs (also gitignored)
runs/
**/__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/
*.egg-info/
.venv/
venv/
.DS_Store
